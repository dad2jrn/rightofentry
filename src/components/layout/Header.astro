---
import Container from '../ui/Container.astro'
import { MobileNav } from './MobileNav'
import Logo from '../brand/Logo.astro'
import { BUSINESS_NAME, BUSINESS_PHONE, BUSINESS_PHONE_HREF } from '../../lib/business-info'
import { cn } from '../../lib/cn'
import { withBase } from '../../lib/paths'

const navLinks = [
  { href: withBase('/'), label: 'Home' },
  { href: withBase('/#services'), label: 'Services' },
  { href: withBase('/#why-us'), label: 'Why Us' },
  { href: withBase('/#about'), label: 'About' },
  { href: withBase('/#contact'), label: 'Contact' },
] as const

const pathname = Astro.url.pathname

const isActiveLink = (href: string) => {
  const [targetPath, hash] = href.split('#')

  if (hash) {
    return false
  }

  const homePath = withBase('/')

  if (targetPath === homePath) {
    return pathname === homePath
  }

  return pathname === targetPath || pathname.startsWith(`${targetPath}/`)
}
---

<header class="border-line/80 bg-paper/92 sticky top-0 z-50 border-b backdrop-blur-md">
  <Container as="div" class="flex min-h-20 items-center gap-4">
    <a
      href={withBase('/')}
      class="text-ink hover:text-ink-soft flex shrink-0 items-center py-3 transition-colors duration-200"
      aria-label={BUSINESS_NAME}
    >
      <Logo class="w-[170px] min-[380px]:w-[184px] sm:w-[214px] lg:w-[228px]" />
    </a>

    <div class="ml-auto md:hidden">
      <MobileNav
        client:media="(max-width: 1023px)"
        businessName={BUSINESS_NAME}
        phone={BUSINESS_PHONE}
        phoneHref={BUSINESS_PHONE_HREF}
        links={navLinks}
        {pathname}
      />
    </div>

    <nav class="ml-auto hidden md:block" aria-label="Primary">
      <ul class="flex items-center gap-8">
        {
          navLinks.map(({ href, label }) => {
            const active = isActiveLink(href)

            return (
              <li>
                <a
                  href={href}
                  data-nav-link
                  aria-current={active ? 'page' : undefined}
                  class={cn(
                    'text-13 text-ink-soft hover:text-ink font-medium transition-colors duration-200',
                    active && 'text-ink underline decoration-1 underline-offset-8',
                  )}
                >
                  {label}
                </a>
              </li>
            )
          })
        }
      </ul>
    </nav>

    <a
      href={BUSINESS_PHONE_HREF}
      class="rounded-sharp bg-ink text-13 tracking-button text-paper hover:bg-ink-soft hidden items-center gap-2 px-5 py-2.5 font-medium transition-colors duration-200 md:inline-flex"
      aria-label={`Call ${BUSINESS_NAME} at ${BUSINESS_PHONE}`}
    >
      <span class="bg-live h-1.5 w-1.5 rounded-full" aria-hidden="true"></span>
      <svg
        class="h-4 w-4"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.8"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path
          d="M22 16.92v3a2 2 0 0 1-2.18 2 19.8 19.8 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.8 19.8 0 0 1 2.12 4.18 2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72l.45 3.57a2 2 0 0 1-.57 1.72L7.91 10.1a16 16 0 0 0 6 6l1.09-1.08a2 2 0 0 1 1.72-.57l3.57.45A2 2 0 0 1 22 16.92z"
        ></path>
      </svg>
      <span>Call Now {BUSINESS_PHONE}</span>
    </a>
  </Container>
</header>

<script>
  const syncHeaderNavState = () => {
    const links = Array.from(document.querySelectorAll<HTMLAnchorElement>('[data-nav-link]'))
    const currentPath = window.location.pathname
    const currentHash = window.location.hash

    for (const link of links) {
      const url = new URL(link.href, window.location.origin)
      const isActive = currentHash
        ? url.pathname === currentPath && url.hash === currentHash
        : url.pathname === currentPath && !url.hash

      link.setAttribute('aria-current', isActive ? 'page' : '')
      link.classList.toggle('text-ink', isActive)
      link.classList.toggle('underline', isActive)
      link.classList.toggle('decoration-1', isActive)
      link.classList.toggle('underline-offset-8', isActive)
    }
  }

  syncHeaderNavState()
  window.addEventListener('hashchange', syncHeaderNavState)
</script>
