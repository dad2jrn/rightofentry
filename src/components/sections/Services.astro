---
import services from '../../content/services.json'
import Container from '../ui/Container.astro'
import SectionHeader from '../ui/SectionHeader.astro'
import ServicesCardGrid from './ServicesCardGrid.astro'

type IconName =
  | 'locked-door'
  | 'cylinder-key'
  | 'deadbolt'
  | 'key-fob'
  | 'keypad-entry'
  | 'clipboard-shield'

type ServiceCard = (typeof services)[number] & { icon: IconName }

const serviceCards = services as ServiceCard[]

// Services 5 and 6 remain in `src/content/services.json` but stay hidden until offered publicly.
const visibleServices = serviceCards.filter((service) => service.offered)
---

<section id="services" class="border-line bg-paper border-t">
  <Container class="py-16 md:py-20 lg:py-24">
    <SectionHeader
      eyebrow="What we do"
      title="Services for every lock and key need"
      description="Clear, practical locksmith work for homes, businesses, and vehicles across the Hampton Roads and Greater Richmond areas."
      class="max-w-3xl"
    />

    <ServicesCardGrid services={visibleServices} variant="numbered" />
  </Container>
</section>
