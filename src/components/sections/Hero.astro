---
import { Image } from 'astro:assets'

import Container from '../ui/Container.astro'
import Button from '../ui/Button.astro'
import heroPhoto from '../../assets/images/hero-locksmith.jpg'
import {
  BUSINESS_PHONE,
  BUSINESS_PHONE_HREF,
  BUSINESS_SERVICE_AREA,
} from '../../lib/business-info'
---

<section id="about" class="bg-ink text-paper relative overflow-hidden py-24 lg:py-32">
  <div
    class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_top_right,_rgb(184_134_58_/_0.24),_transparent_42%),linear-gradient(180deg,_rgb(255_255_255_/_0.02),_transparent_38%)]"
    aria-hidden="true"
  >
  </div>

  <Container class="relative">
    <div
      class="grid items-center gap-12 lg:grid-cols-[minmax(0,1fr)_minmax(420px,520px)] lg:gap-16"
    >
      <div>
        <p class="text-11 tracking-caps-3 text-accent mb-4 font-medium uppercase">
          Serving {BUSINESS_SERVICE_AREA}
        </p>

        <h1
          class="font-display leading-hero text-paper max-w-[12ch] text-[3.25rem] font-medium tracking-[0.05em] sm:text-[3.6rem] xl:text-[4.15rem]"
        >
          Locksmith &amp; Security Services you can call at<br />2 AM.
        </h1>

        <p class="text-16 leading-body text-paper/78 sm:text-18 mt-6 max-w-2xl">
          Licensed, insured, and local. Emergency lockouts, rekeys, lock installation, and security
          assessments for homes, vehicles, and businesses across Hampton Roads and Greater
          Richmond.
        </p>

        <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:flex-wrap">
          <Button
            href={BUSINESS_PHONE_HREF}
            variant="brass"
            size="lg"
            class="text-ink justify-center shadow-[0_18px_40px_rgb(184_134_58_/_0.3)]"
          >
            <span class="text-ink inline-flex items-center gap-2">
              <span class="bg-live h-1.5 w-1.5 rounded-full" aria-hidden="true"></span>
              <svg
                class="text-ink h-4 w-4"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path
                  d="M22 16.92v3a2 2 0 0 1-2.18 2 19.8 19.8 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.8 19.8 0 0 1 2.12 4.18 2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72l.45 3.57a2 2 0 0 1-.57 1.72L7.91 10.1a16 16 0 0 0 6 6l1.09-1.08a2 2 0 0 1 1.72-.57l3.57.45A2 2 0 0 1 22 16.92z"
                ></path>
              </svg>
              <span class="text-ink">Call {BUSINESS_PHONE}</span>
            </span>
          </Button>

          <a
            href="#services"
            class="rounded-sharp border-paper-15 text-14 tracking-button text-paper hover:border-paper hover:bg-paper hover:text-ink inline-flex items-center justify-center border px-7 py-4 font-medium transition-colors duration-200"
          >
            See services
          </a>
        </div>

        <div
          class="text-12 tracking-caps-2 text-paper/70 mt-8 flex flex-wrap gap-x-8 gap-y-3 font-medium uppercase"
        >
          <span>Licensed in Virginia</span>
          <span>Insured &amp; Bonded</span>
          <span>Disabled Veteran-Owned</span>
        </div>
      </div>

      <div class="hidden lg:block">
        <div
          class="rounded-frame border-paper-15 bg-paper/5 relative overflow-hidden border shadow-[0_28px_80px_rgb(0_0_0_/_0.28)]"
        >
          <Image
            src={heroPhoto}
            alt="Locksmith cylinders, keys, and lock hardware arranged on a work mat"
            widths={[320, 480, 640, 800, 960]}
            sizes="(min-width: 1024px) 520px, (min-width: 640px) 70vw, 100vw"
            width={960}
            height={1200}
            loading="eager"
            fetchpriority="high"
            class="aspect-[4/5] w-full object-cover"
          />

          <div
            class="from-ink/80 via-ink/20 pointer-events-none absolute inset-x-0 bottom-0 bg-gradient-to-t to-transparent p-6"
          >
            <p class="text-11 tracking-caps-3 text-paper/80 font-medium uppercase">
              Professional Locksmith services
            </p>
          </div>
        </div>
      </div>
    </div>
  </Container>
</section>
