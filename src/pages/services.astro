---
import BaseLayout from '../layouts/BaseLayout.astro'
import Container from '../components/ui/Container.astro'
import ServiceIcon from '../components/ui/ServiceIcon.astro'
import FinalCTA from '../components/sections/FinalCTA.astro'
import { BUSINESS_NAME, BUSINESS_SERVICE_AREA } from '../lib/business-info'
import { allServices } from '../lib/service-catalog'
import { cn } from '../lib/cn'

const pageTitle = `Locksmith Services in Williamsburg and ${BUSINESS_SERVICE_AREA} | ${BUSINESS_NAME}`
const pageDescription =
  'Locksmith services for Williamsburg, Toano, and surrounding Virginia communities. Emergency lockouts, rekeying, lock installation, automotive keys, and practical security support from a local locksmith.'
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <section class="border-line bg-paper border-b" aria-labelledby="services-page-title">
    <Container class="py-14 md:py-18 lg:py-20">
      <div class="max-w-4xl">
        <p class="text-11 tracking-caps-3 text-accent-dark mb-4 font-medium uppercase">
          Locksmith services
        </p>
        <div class="flex flex-col gap-5 lg:flex-row lg:items-end lg:justify-between lg:gap-10">
          <div class="max-w-2xl">
            <h1
              id="services-page-title"
              class="font-display text-36 tracking-h2 text-ink text-balance font-medium leading-display md:text-52 md:tracking-hero"
            >
              Services
            </h1>
            <p class="text-16 leading-body text-ink-soft mt-5 max-w-[58ch]">
              Clear, longer-form details on each service so you can quickly decide what fits your
              situation before you call.
            </p>
          </div>

          <p class="text-13 tracking-caps-2 text-muted max-w-sm font-medium uppercase">
            Serving Williamsburg, Toano, and the wider {BUSINESS_SERVICE_AREA}
          </p>
        </div>
      </div>
    </Container>
  </section>

  <section class="bg-paper" aria-label="Service details">
    <Container class="py-12 md:py-16 lg:py-20">
      <div class="space-y-6 md:space-y-8">
        {
          allServices.map((service, index) => {
            const isReversed = index % 2 === 1

            return (
              <article
                id={service.slug}
                aria-labelledby={`${service.slug}-title`}
                class="rounded-frame border-line bg-surface overflow-hidden border"
              >
                <div class="grid lg:grid-cols-2">
                  <div
                    class={cn(
                      'p-6 md:p-8 lg:p-10',
                      isReversed ? 'lg:order-2' : 'lg:order-1',
                    )}
                  >
                    <div class="flex flex-wrap items-start justify-between gap-4">
                      <div>
                        <p class="text-11 tracking-caps-3 text-accent-dark font-medium uppercase">
                          Service
                        </p>
                        <h2
                          id={`${service.slug}-title`}
                          class="text-28 tracking-h2-sm text-ink mt-3 font-medium leading-tight md:text-32"
                        >
                          {service.title}
                        </h2>
                      </div>

                      <span class="rounded-card border-line bg-paper text-accent inline-flex h-12 w-12 items-center justify-center border">
                        <ServiceIcon name={service.icon} class="h-6 w-6" />
                      </span>
                    </div>

                    <div class="mt-5 flex flex-wrap items-center gap-3">
                      <span class="rounded-sharp border-line text-12 tracking-button text-ink inline-flex items-center border px-3 py-2 font-medium">
                        {service.pricing.display}
                      </span>
                      <span class="text-12 tracking-caps-2 text-muted font-medium uppercase">
                        {service.offered
                          ? 'Available for service calls'
                          : 'Call to confirm current availability'}
                      </span>
                    </div>

                    <div class="prose prose-brand mt-6 max-w-none">
                      {service.longDescription.map((paragraph) => (
                        <p>{paragraph}</p>
                      ))}
                    </div>

                    {service.pricing.modifiers.length > 0 && (
                      <div class="border-line mt-6 border-t pt-5">
                        <p class="text-11 tracking-caps-3 text-muted font-medium uppercase">
                          Pricing notes
                        </p>
                        <ul class="mt-3 space-y-2">
                          {service.pricing.modifiers.map((modifier) => (
                            <li class="text-14 leading-snug text-ink-soft">
                              <span class="text-ink font-medium">{modifier.label}:</span>{' '}
                              {modifier.display}
                            </li>
                          ))}
                        </ul>
                      </div>
                    )}
                  </div>

                  <div
                    class={cn(
                      'border-line bg-paper flex border-t p-6 md:p-8 lg:border-t-0 lg:p-10',
                      isReversed ? 'lg:order-1 lg:border-r' : 'lg:order-2 lg:border-l',
                    )}
                  >
                    <div class="flex w-full flex-col justify-between rounded-card border border-transparent">
                      <div>
                        <p class="text-11 tracking-caps-3 text-muted font-medium uppercase">
                          At a glance
                        </p>
                        <p class="text-22 tracking-h3 text-ink mt-4 max-w-[22ch] font-medium leading-tight md:text-28">
                          {service.shortDescription}
                        </p>
                      </div>

                      <div class="border-line mt-8 border-t pt-6">
                        <div class="flex items-center gap-3">
                          <span class="rounded-card bg-surface text-accent inline-flex h-11 w-11 items-center justify-center border border-transparent">
                            <ServiceIcon name={service.icon} class="h-5.5 w-5.5" />
                          </span>
                          <div>
                            <p class="text-11 tracking-caps-3 text-muted font-medium uppercase">
                              Base pricing
                            </p>
                            <p class="text-16 text-ink mt-1 font-medium">{service.pricing.display}</p>
                          </div>
                        </div>

                        <p class="text-13 leading-snug text-ink-soft mt-5 max-w-[36ch]">
                          {service.pricing.modifiers.length > 0
                            ? 'Any service-specific modifiers are listed separately so the base rate stays clear.'
                            : 'Pricing is shown as the current starting point or service range for this category.'}
                        </p>
                      </div>
                    </div>
                  </div>
                </div>
              </article>
            )
          })
        }
      </div>
    </Container>
  </section>

  <FinalCTA />
</BaseLayout>
