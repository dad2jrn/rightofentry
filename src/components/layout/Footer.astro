---
import Container from '../ui/Container.astro'
import {
  BUSINESS_EMAIL,
  BUSINESS_HOURS_LIST,
  BUSINESS_LICENSE_STATUS,
  BUSINESS_NAME,
  BUSINESS_PHONE,
  BUSINESS_PHONE_HREF,
  BUSINESS_SOCIAL_LINKS,
  BUSINESS_TAGLINE,
  BUSINESS_URL,
  PRIVACY_POLICY_HREF,
} from '../../lib/business-info'

const currentYear = new Date().getFullYear()

const quickLinks = [
  { href: '/', label: 'Home' },
  { href: '/services', label: 'Services' },
  { href: '/about', label: 'About' },
  { href: '/contact', label: 'Contact' },
] as const

const socialIcons = {
  Facebook: 'M22 12a10 10 0 1 0-11.56 9.88v-6.99H7.9V12h2.54V9.8c0-2.5 1.5-3.88 3.78-3.88 1.09 0 2.23.2 2.23.2v2.46h-1.26c-1.24 0-1.63.77-1.63 1.56V12h2.77l-.44 2.89h-2.33v6.99A10 10 0 0 0 22 12Z',
  Instagram:
    'M7.75 2h8.5A5.75 5.75 0 0 1 22 7.75v8.5A5.75 5.75 0 0 1 16.25 22h-8.5A5.75 5.75 0 0 1 2 16.25v-8.5A5.75 5.75 0 0 1 7.75 2Zm0 1.5A4.25 4.25 0 0 0 3.5 7.75v8.5a4.25 4.25 0 0 0 4.25 4.25h8.5a4.25 4.25 0 0 0 4.25-4.25v-8.5A4.25 4.25 0 0 0 16.25 3.5h-8.5Zm8.88 2.25a1.12 1.12 0 1 1 0 2.25 1.12 1.12 0 0 1 0-2.25ZM12 7a5 5 0 1 1 0 10 5 5 0 0 1 0-10Zm0 1.5A3.5 3.5 0 1 0 12 15.5 3.5 3.5 0 0 0 12 8.5Z',
  'Google Business':
    'M12 2a10 10 0 1 0 6.32 17.75l-1.2-1.02a8.5 8.5 0 1 1 2.56-6.1H12v1.5h6.05a6.01 6.01 0 0 1-2.2 3.52l1.2 1.03A7.49 7.49 0 0 0 20 12c0-.5-.05-1-.14-1.47H12V12h7.63A8.44 8.44 0 0 0 12 2Z',
} as const
---

<footer class="border-t border-paper-15 bg-ink text-paper" aria-label="Site footer">
  <Container class="py-12 md:py-16">
    <div class="grid gap-10 border-b border-paper-15 pb-10 md:grid-cols-[1.25fr_0.85fr_1fr] md:gap-8 md:pb-12">
      <div class="max-w-md">
        <a
          href="/"
          class="inline-flex flex-col gap-2 text-paper transition-colors duration-200 hover:text-paper-60"
          aria-label={BUSINESS_NAME}
        >
          <span class="text-15 font-semibold tracking-logo">{BUSINESS_NAME}</span>
          <span class="block h-px w-13 bg-accent" aria-hidden="true"></span>
        </a>

        <p class="mt-5 max-w-sm text-14 leading-snug text-paper-60">
          {BUSINESS_TAGLINE}
        </p>

        <div class="mt-6">
          <p class="text-11 font-medium uppercase tracking-caps-3 text-paper-60">
            Follow along
          </p>
          <ul class="mt-3 flex items-center gap-3">
            {
              BUSINESS_SOCIAL_LINKS.map(({ label, href }) => (
                <li>
                  <a
                    href={href}
                    aria-label={label}
                    class="inline-flex h-10 w-10 items-center justify-center rounded-card border border-paper-15 text-paper transition-colors duration-200 hover:border-accent hover:text-accent"
                  >
                    <svg viewBox="0 0 24 24" class="h-4 w-4 fill-current" aria-hidden="true">
                      <path d={socialIcons[label]}></path>
                    </svg>
                  </a>
                </li>
              ))
            }
          </ul>
        </div>

        <div class="mt-6 inline-flex items-center rounded-card border border-paper-15 px-3 py-2 text-12 font-medium uppercase tracking-caps-2 text-paper-60">
          Licensing badge placeholder
        </div>
      </div>

      <div>
        <p class="text-11 font-medium uppercase tracking-caps-3 text-paper-60">
          Quick links
        </p>
        <ul class="mt-4 space-y-3">
          {
            quickLinks.map(({ href, label }) => (
              <li>
                <a
                  href={href}
                  class="text-14 text-paper transition-colors duration-200 hover:text-accent"
                >
                  {label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div>
        <p class="text-11 font-medium uppercase tracking-caps-3 text-paper-60">
          Contact
        </p>

        <address class="mt-4 not-italic">
          <ul class="space-y-4 text-14 leading-snug text-paper-60">
            <li>
              <a
                href={BUSINESS_PHONE_HREF}
                class="text-paper transition-colors duration-200 hover:text-accent"
              >
                {BUSINESS_PHONE}
              </a>
            </li>
            <li>
              <a
                href={`mailto:${BUSINESS_EMAIL}`}
                class="text-paper transition-colors duration-200 hover:text-accent"
              >
                {BUSINESS_EMAIL}
              </a>
            </li>
          </ul>
        </address>

        <div class="mt-6">
          <p class="text-11 font-medium uppercase tracking-caps-3 text-paper-60">
            Hours
          </p>
          <ul class="mt-3 space-y-2 text-13 text-paper-60">
            {
              BUSINESS_HOURS_LIST.map(({ label, hours }) => (
                <li class="flex items-start justify-between gap-4 border-t border-paper-15 pt-2 first:border-t-0 first:pt-0">
                  <span>{label}</span>
                  <span class="text-paper">{hours}</span>
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </div>

    <div class="flex flex-col gap-3 pt-6 text-12 text-paper-60 md:flex-row md:items-center md:justify-between">
      <p>
        &copy; {currentYear} <a href={BUSINESS_URL} class="transition-colors duration-200 hover:text-accent">{BUSINESS_NAME}</a>. All rights reserved.
      </p>
      <div class="flex flex-col gap-3 md:flex-row md:items-center md:gap-6">
        <p>{BUSINESS_LICENSE_STATUS}</p>
        <a href={PRIVACY_POLICY_HREF} class="transition-colors duration-200 hover:text-accent">
          Privacy Policy
        </a>
      </div>
    </div>
  </Container>
</footer>
