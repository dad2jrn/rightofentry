---
import { getCollection } from 'astro:content'

import BaseLayout from '../layouts/BaseLayout.astro'
import Hero from '../components/sections/Hero.astro'
import Services from '../components/sections/Services.astro'
import WhyUs from '../components/sections/WhyUs.astro'
import Testimonials from '../components/sections/Testimonials'
import FinalCTA from '../components/sections/FinalCTA.astro'
import { HOME_SECTION_FLAGS } from '../lib/home-sections'
import { BUSINESS_SERVICE_AREA, BUSINESS_URL } from '../lib/business-info'

const testimonials = HOME_SECTION_FLAGS.testimonials.enabled
  ? (await getCollection('testimonials'))
      .sort((left, right) => left.id.localeCompare(right.id))
      .map(({ data, id }) => ({
        id,
        ...data,
      }))
  : []
---

<BaseLayout
  title={`Right of Entry Lock & Security | Locksmith, ${BUSINESS_SERVICE_AREA}`}
  description={`Licensed 24/7 locksmith in ${BUSINESS_SERVICE_AREA}. Emergency lockouts, rekeying, lock installation, vehicle entry, and commercial security.`}
  canonical={BUSINESS_URL}
>
  <Hero />
  <Services />
  <WhyUs />
  {HOME_SECTION_FLAGS.testimonials.enabled && <Testimonials client:visible testimonials={testimonials} />}
  <FinalCTA />
</BaseLayout>
