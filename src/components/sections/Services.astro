---
import { BUSINESS_SERVICE_AREA } from '../../lib/business-info'
import { featuredServices } from '../../lib/service-catalog'

import Container from '../ui/Container.astro'
import SectionHeader from '../ui/SectionHeader.astro'
import ServicesCardGrid from './ServicesCardGrid.astro'
---

<section id="services" class="border-line bg-paper border-t">
  <Container class="py-16 md:py-20 lg:py-24">
    <SectionHeader
      eyebrow="What we do"
      title="Services for every lock and key need"
      description={`Clear, practical locksmith work for homes, businesses, and vehicles across ${BUSINESS_SERVICE_AREA}.`}
      class="max-w-3xl"
    />

    <ServicesCardGrid services={featuredServices} variant="numbered" />
  </Container>
</section>
