---
import '@fontsource-variable/inter/wght.css'
import '@fontsource/cal-sans/400.css'
import '../styles/globals.css'

import interLatinWoff2 from '@fontsource-variable/inter/files/inter-latin-wght-normal.woff2'
import calSansLatinWoff2 from '@fontsource/cal-sans/files/cal-sans-latin-400-normal.woff2'
import logoShieldPng from '../../logos/right-of-entry-shield-black.png'

import Header from '../components/layout/Header.astro'
import Footer from '../components/layout/Footer.astro'
import { localBusinessSchema } from '../lib/structured-data'

type Props = {
  title: string
  description?: string
  ogImage?: string
  canonical?: string
}

const { title, description, ogImage = logoShieldPng.src, canonical } = Astro.props

const canonicalURL = canonical ?? new URL(Astro.url.pathname, Astro.site).href
const ogImageURL = new URL(ogImage, Astro.site).href
const schema = localBusinessSchema()
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    {description && <meta name="twitter:description" content={description} />}
    <meta name="twitter:image" content={ogImageURL} />

    <!-- Favicons -->
    <link rel="icon" type="image/png" href={logoShieldPng.src} />
    <link rel="apple-touch-icon" href={logoShieldPng.src} />

    <!-- Preload hero-visible font weights -->
    <link rel="preload" as="font" type="font/woff2" crossorigin href={interLatinWoff2} />
    <link rel="preload" as="font" type="font/woff2" crossorigin href={calSansLatinWoff2} />

    <!-- LocalBusiness structured data -->
    <script type="application/ld+json" set:html={JSON.stringify(schema)}></script>
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
  </body>
</html>
